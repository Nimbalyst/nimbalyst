{
  "name": "nimbalyst-monorepo",
  "version": "0.33.1",
  "private": true,
  "description": "Monorepo for Nimbalyst - A rich text editor built with Meta's Lexical framework",
  "author": "Stravu Team",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/nimbalyst.git"
  },
  "scripts": {
    "dev": "npm run dev --prefix packages/playground",
    "build": "npm run build --prefix packages/rexical",
    "build:playground": "npm run build --prefix packages/playground",
    "preview": "npm run preview --prefix packages/playground",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test:unit",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top",
    "clean": "rm -rf packages/*/node_modules/.vite packages/*/dist node_modules/.cache",
    "clean:full": "rm -rf packages/*/node_modules packages/*/dist node_modules && npm install",
    "cap:dev": "npm run dev --prefix packages/capacitor",
    "cap:build": "npm run build --prefix packages/capacitor",
    "cap:ios": "npm run ios --prefix packages/capacitor",
    "cap:android": "npm run android --prefix packages/capacitor",
    "cap:sync": "npm run cap:sync --prefix packages/capacitor",
    "collab:dev": "npm run dev --prefix packages/collab",
    "collab:build": "npm run build --prefix packages/collab",
    "collab:start": "npm start --prefix packages/collab",
    "collabv2:dev": "npm run dev --prefix packages/collabv2",
    "collabv2:build": "npm run build --prefix packages/collabv2",
    "collabv2:deploy": "npm run deploy --prefix packages/collabv2",
    "collabv2:test": "npm run test --prefix packages/collabv2"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@electric-sql/pglite-tools": "^0.2.16",
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.0.0",
    "ajv": "^8.17.1",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.0.12",
    "terser": "^5.31.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "packages/playground",
    "packages/electron",
    "packages/runtime",
    "packages/core",
    "packages/rexical",
    "packages/collabv3",
    "packages/capacitor",
    "packages/extension-sdk",
    "packages/extensions/*"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.32",
    "@types/node-forge": "^1.3.14",
    "ajv-formats": "^3.0.1",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.6",
    "es-module-shims": "^2.7.0",
    "eventsource": "^4.1.0",
    "eventsource-parser": "^3.0.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.3.2",
    "openai": "^6.9.1",
    "pkce-challenge": "^5.0.0",
    "raw-body": "^3.0.1",
    "virtua": "^0.48.2",
    "zod-to-json-schema": "^3.25.0"
  },
  "overrides": {
    "prismjs": "^1.30.0"
  }
}
