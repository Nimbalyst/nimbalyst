{
  "name": "stravu-editor",
  "version": "0.33.1",
  "description": "A rich text editor built with Meta's Lexical framework, featuring markdown support, tables, and comprehensive editing capabilities",
  "keywords": [
    "react",
    "editor",
    "lexical",
    "markdown",
    "rich-text",
    "wysiwyg"
  ],
  "author": "Stravu Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/stravu-editor.git"
  },
  "bugs": {
    "url": "https://github.com/stravu/stravu-editor/issues"
  },
  "homepage": "https://github.com/stravu/stravu-editor#readme",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host --port 4000",
    "build": "vite build --mode library",
    "build-dev": "vite build",
    "build-prod": "vite build --mode production",
    "build-analyze": "vite build --mode analyze",
    "build-vercel": "(cd ../../ && node ./scripts/build.js) && pnpm run build-dev",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "lodash-es": "^4.17.21",
    "prettier": "^2.8.8",
    "react-error-boundary": "^3.1.4",
    "y-websocket": "^1.5.4",
    "yjs": ">=13.5.42"
  },
  "peerDependencies": {
    "@lexical/clipboard": "^0.33.2-nightly.20250724.0",
    "@lexical/code": "^0.33.2-nightly.20250724.0",
    "@lexical/code-shiki": "^0.33.2-nightly.20250724.0",
    "@lexical/file": "^0.33.2-nightly.20250724.0",
    "@lexical/hashtag": "^0.33.2-nightly.20250724.0",
    "@lexical/link": "^0.33.2-nightly.20250724.0",
    "@lexical/list": "^0.33.2-nightly.20250724.0",
    "@lexical/mark": "^0.33.2-nightly.20250724.0",
    "@lexical/markdown": "^0.33.2-nightly.20250724.0",
    "@lexical/overflow": "^0.33.2-nightly.20250724.0",
    "@lexical/plain-text": "^0.33.2-nightly.20250724.0",
    "@lexical/react": "^0.33.2-nightly.20250724.0",
    "@lexical/rich-text": "^0.33.2-nightly.20250724.0",
    "@lexical/selection": "^0.33.2-nightly.20250724.0",
    "@lexical/table": "^0.33.2-nightly.20250724.0",
    "@lexical/utils": "^0.33.2-nightly.20250724.0",
    "@lexical/yjs": "^0.33.2-nightly.20250724.0",
    "lexical": "^0.33.2-nightly.20250724.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@types/lodash-es": "^4.14.182",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "^5.0.0",
    "vite": "^5.2.11",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-static-copy": "^2.3.0"
  },
  "sideEffects": false
}
