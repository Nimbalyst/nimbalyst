{
  "name": "nimbalyst-monorepo",
  "version": "0.33.1",
  "private": true,
  "description": "Monorepo for Nimbalyst - A rich text editor built with Meta's Lexical framework",
  "author": "Stravu Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/nimbalyst.git"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix packages/playground",
    "build": "npm run build --prefix packages/rexical",
    "build:playground": "npm run build --prefix packages/playground",
    "preview": "npm run preview --prefix packages/playground",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top",
    "clean": "rm -rf packages/*/node_modules/.vite packages/*/dist node_modules/.cache",
    "clean:full": "rm -rf packages/*/node_modules packages/*/dist node_modules && npm install",
    "tauri:dev": "npm run tauri dev --prefix packages/tauri",
    "tauri:build": "npm run tauri build --prefix packages/tauri",
    "cap:dev": "npm run dev --prefix packages/capacitor",
    "cap:build": "npm run build --prefix packages/capacitor",
    "cap:ios": "npm run ios --prefix packages/capacitor",
    "cap:android": "npm run android --prefix packages/capacitor",
    "cap:sync": "npm run cap:sync --prefix packages/capacitor"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@electric-sql/pglite-tools": "^0.2.16",
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.0.0",
    "ajv": "^8.17.1",
    "concurrently": "^9.2.0",
    "electron-builder": "^26.0.12",
    "terser": "^5.31.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "packages/playground",
    "packages/electron",
    "packages/runtime",
    "packages/core",
    "packages/rexical"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.37",
    "cors": "^2.8.5",
    "eventsource": "^4.1.0",
    "eventsource-parser": "^3.0.6",
    "express": "^5.1.0"
  },
  "overrides": {
    "prismjs": "^1.30.0",
    "@electric-sql/pglite-socket": {
      "@electric-sql/pglite": "$@electric-sql/pglite"
    }
  }
}
