{
  "name": "stravu-editor-monorepo",
  "version": "0.33.1",
  "private": true,
  "description": "Monorepo for Stravu Editor - A rich text editor built with Meta's Lexical framework",
  "author": "Stravu Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/stravu-editor.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -n lib,playground -c magenta,cyan \"pnpm:dev:lib\" \"pnpm:dev:playground\"",
    "dev:lib": "pnpm --filter stravu-editor vite",
    "dev:playground": "pnpm --filter @stravu-editor/playground dev",
    "dev:old": "pnpm --filter @stravu-editor/playground dev",
    "build": "pnpm --filter stravu-editor build",
    "build:playground": "pnpm --filter @stravu-editor/playground build",
    "preview": "pnpm --filter @stravu-editor/playground preview",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.0.0"
}