{
  "name": "stravu-editor-monorepo",
  "version": "0.33.1",
  "private": true,
  "description": "Monorepo for Stravu Editor - A rich text editor built with Meta's Lexical framework",
  "author": "Stravu Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/stravu-editor.git"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix packages/playground",
    "build": "npm run build --prefix packages/stravu-editor",
    "build:playground": "npm run build --prefix packages/playground",
    "preview": "npm run preview --prefix packages/playground",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top",
    "clean": "rm -rf packages/*/node_modules/.vite packages/*/dist node_modules/.cache",
    "clean:full": "rm -rf packages/*/node_modules packages/*/dist node_modules && npm install"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "packages/stravu-editor",
    "packages/playground",
    "packages/electron"
  ]
}
