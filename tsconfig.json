{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [],
    "paths": {
      "@nimbalyst/runtime": ["./packages/runtime/src/index.ts"],
      "@nimbalyst/runtime/*": ["./packages/runtime/src/*"],
      "rexical": ["./packages/rexical/src/index.ts"],
      "rexical/*": ["./packages/rexical/src/*"]
    }
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/*.d.ts",
    "**/e2e/**",
    "packages/capacitor",
    "packages/tauri",
    "packages/playground",
    "packages/collabv3",
    "packages/electron/release",
    "worktrees",
    "test-utils"
  ]
}
