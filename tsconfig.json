{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": []
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/*.d.ts",
    "packages/capacitor",
    "packages/tauri",
    "packages/playground",
    "worktrees",
    "test-utils"
  ]
}
