{
  "name": "@nimbalyst/extension-sdk",
  "version": "0.1.0",
  "description": "SDK for building Nimbalyst extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/nimbalyst/nimbalyst.git",
    "directory": "packages/extension-sdk"
  },
  "homepage": "https://docs.nimbalyst.com/extensions",
  "bugs": {
    "url": "https://github.com/nimbalyst/nimbalyst/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2"
  },
  "keywords": [
    "nimbalyst",
    "extension",
    "sdk",
    "plugin",
    "custom-editor",
    "ai-tools"
  ],
  "license": "MIT"
}
