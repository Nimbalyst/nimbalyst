{
  "name": "@nimbalyst/extension-sdk",
  "version": "0.1.0",
  "description": "SDK for building Nimbalyst extensions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2"
  },
  "keywords": [
    "nimbalyst",
    "extension",
    "sdk",
    "plugin"
  ],
  "license": "MIT"
}
