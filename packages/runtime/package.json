{
  "name": "@stravu/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Preditor runtime: sessions, collab, AI hooks, plugins",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai/EditorRegistry": {
      "import": "./dist/ai/EditorRegistry.js",
      "types": "./dist/ai/EditorRegistry.d.ts"
    },
    "./ai/plugins/AIChatIntegrationPlugin": {
      "import": "./dist/ai/plugins/AIChatIntegrationPlugin/index.js",
      "types": "./dist/ai/plugins/AIChatIntegrationPlugin/index.d.ts"
    },
    "./ai/server": {
      "import": "./dist/ai/server/index.js",
      "types": "./dist/ai/server/index.d.ts"
    },
    "./ai/server/types": {
      "import": "./dist/ai/server/types.js",
      "types": "./dist/ai/server/types.d.ts"
    },
    "./ai/types": {
      "import": "./dist/ai/types.js",
      "types": "./dist/ai/types.d.ts"
    },
    "./ai/server/providers/ClaudeProvider": {
      "import": "./dist/ai/server/providers/ClaudeProvider.js",
      "types": "./dist/ai/server/providers/ClaudeProvider.d.ts"
    },
    "./ai/tools": {
      "import": "./dist/ai/tools/index.js",
      "types": "./dist/ai/tools/index.d.ts"
    },
    "./ai/modelConstants": {
      "import": "./dist/ai/modelConstants.js",
      "types": "./dist/ai/modelConstants.d.ts"
    },
    "./agents": {
      "import": "./dist/agents/index.js",
      "types": "./dist/agents/index.d.ts"
    },
    "./ui/AgentTranscript": {
      "import": "./dist/ui/AgentTranscript/index.js",
      "types": "./dist/ui/AgentTranscript/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "openai": "^4.56.0",
    "rexical": "file:../rexical",
    "yjs": ">=13.5.42",
    "y-websocket": "^1.5.4"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
