{
  "name": "@nimbalyst/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Nimbalyst runtime: sessions, collab, AI hooks, plugins",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai/EditorRegistry": {
      "import": "./dist/ai/EditorRegistry.js",
      "types": "./dist/ai/EditorRegistry.d.ts"
    },
    "./ai/plugins/AIChatIntegrationPlugin": {
      "import": "./dist/ai/plugins/AIChatIntegrationPlugin/index.js",
      "types": "./dist/ai/plugins/AIChatIntegrationPlugin/index.d.ts"
    },
    "./ai/server": {
      "import": "./dist/ai/server/index.js",
      "types": "./dist/ai/server/index.d.ts"
    },
    "./ai/server/types": {
      "import": "./dist/ai/server/types.js",
      "types": "./dist/ai/server/types.d.ts"
    },
    "./ai/types": {
      "import": "./dist/ai/types.js",
      "types": "./dist/ai/types.d.ts"
    },
    "./ai/server/providers/ClaudeProvider": {
      "import": "./dist/ai/server/providers/ClaudeProvider.js",
      "types": "./dist/ai/server/providers/ClaudeProvider.d.ts"
    },
    "./ai/tools": {
      "import": "./dist/ai/tools/index.js",
      "types": "./dist/ai/tools/index.d.ts"
    },
    "./ai/modelConstants": {
      "import": "./dist/ai/modelConstants.js",
      "types": "./dist/ai/modelConstants.d.ts"
    },
    "./agents": {
      "import": "./dist/agents/index.js",
      "types": "./dist/agents/index.d.ts"
    },
    "./ui/AgentTranscript": {
      "import": "./dist/ui/AgentTranscript/index.js",
      "types": "./dist/ui/AgentTranscript/index.d.ts"
    },
    "./plugins/TrackerPlugin": {
      "import": "./dist/plugins/TrackerPlugin/index.js",
      "types": "./dist/plugins/TrackerPlugin/index.d.ts"
    },
    "./plugins/TrackerPlugin/documentHeader": {
      "import": "./dist/plugins/TrackerPlugin/documentHeader/index.js",
      "types": "./dist/plugins/TrackerPlugin/documentHeader/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@excalidraw/excalidraw": "0.17.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "esbuild": "0.25.10",
    "happy-dom": "^20.0.4",
    "openai": "^4.56.0",
    "posthog-js": "^1.280.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.5.0",
    "remark-gfm": "^4.0.1",
    "rexical": "file:../rexical",
    "vite": "7.1.12",
    "y-websocket": "^1.5.4",
    "yjs": ">=13.5.42"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
