{
  "id": "com.nimbalyst.datamodellm",
  "name": "DatamodelLM",
  "version": "1.0.0",
  "description": "AI-assisted data modeling with visual entity-relationship diagrams",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.prisma"],
        "displayName": "Data Model Editor",
        "component": "DatamodelLMEditor",
        "supportsSourceMode": true
      }
    ],
    "aiTools": [
      "datamodellm.get_schema",
      "datamodellm.capture_screenshot"
    ],
    "fileIcons": {
      "*.prisma": "database"
    },
    "newFileMenu": [
      {
        "extension": ".prisma",
        "displayName": "Data Model",
        "icon": "database",
        "defaultContent": "// @nimbalyst {\"viewport\":{\"x\":0,\"y\":0,\"zoom\":1},\"positions\":{},\"entityViewMode\":\"standard\"}\n\ndatasource db {\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n}\n"
      }
    ],
    "slashCommands": [
      {
        "id": "datamodellm.insert",
        "title": "Data Model",
        "description": "Insert a data model diagram",
        "icon": "database",
        "keywords": ["datamodel", "schema", "erd", "database", "entity", "prisma"],
        "handler": "handleInsertDataModel"
      }
    ],
    "nodes": ["DataModelNode"],
    "transformers": ["DATAMODEL_TRANSFORMER"],
    "hostComponents": ["DataModelPickerMenuHost"],
    "claudePlugin": {
      "path": "claude-plugin",
      "displayName": "Data Model Commands",
      "description": "Provides /datamodel command for creating Prisma-based data models with full schema syntax guidance",
      "enabledByDefault": true,
      "commands": [
        {
          "name": "datamodel",
          "description": "Create or modify Prisma-based data models"
        }
      ]
    }
  }
}
