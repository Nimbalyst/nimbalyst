{
  "id": "com.nimbalyst.csv-spreadsheet",
  "name": "CSV Spreadsheet",
  "version": "1.0.0",
  "description": "Edit CSV files with a spreadsheet interface and formula support",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.csv", "*.tsv"],
        "displayName": "Spreadsheet Editor",
        "component": "SpreadsheetEditor",
        "supportsSourceMode": true
      }
    ],
    "fileIcons": {
      "*.csv": "table",
      "*.tsv": "table"
    },
    "newFileMenu": [
      {
        "extension": ".csv",
        "displayName": "CSV Spreadsheet",
        "icon": "table",
        "defaultContent": "Column A,Column B,Column C\n,,\n,,\n,,"
      }
    ],
    "configuration": {
      "title": "CSV Spreadsheet Settings",
      "properties": {
        "metadataStorage": {
          "type": "string",
          "enum": ["inline", "sidecar"],
          "enumDescriptions": [
            "Store metadata as a comment in the CSV file (default)",
            "Store metadata in a separate .csvmeta file"
          ],
          "default": "inline",
          "description": "Where to store spreadsheet metadata (headers, frozen columns, formatting)",
          "scope": "workspace"
        }
      }
    }
  }
}
