{
  "id": "com.nimbalyst.mockuplm",
  "name": "MockupLM",
  "version": "1.0.0",
  "description": "Visual UX mockup creation with HTML/CSS for planning and design",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.mockup.html"],
        "displayName": "Mockup Editor",
        "component": "MockupEditor",
        "supportsSourceMode": true
      }
    ],
    "fileIcons": {
      "*.mockup.html": "palette"
    },
    "newFileMenu": [
      {
        "extension": ".mockup.html",
        "displayName": "Mockup",
        "icon": "palette",
        "defaultContent": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body {\n      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      margin: 0;\n      padding: 20px;\n    }\n  </style>\n</head>\n<body>\n  <h1>New Mockup</h1>\n  <p>Start designing your UI here.</p>\n</body>\n</html>"
      }
    ],
    "claudePlugin": {
      "path": "claude-plugin",
      "displayName": "MockupLM",
      "description": "Visual UX mockup creation with HTML/CSS",
      "enabledByDefault": true,
      "commands": [
        {
          "name": "mockup",
          "description": "Create visual UX mockups"
        }
      ]
    }
  }
}
