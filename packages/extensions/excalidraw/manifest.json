{
  "id": "com.nimbalyst.excalidraw",
  "name": "Excalidraw",
  "version": "1.0.0",
  "description": "Excalidraw diagram editor with AI-assisted editing",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.excalidraw"],
        "displayName": "Excalidraw Editor",
        "component": "ExcalidrawEditor",
        "supportsSourceMode": true
      }
    ],
    "aiTools": [
      "excalidraw.get_elements",
      "excalidraw.add_rectangle",
      "excalidraw.add_arrow",
      "excalidraw.update_element",
      "excalidraw.remove_element",
      "excalidraw.relayout",
      "excalidraw.import_mermaid",
      "excalidraw.clear_all",
      "excalidraw.add_frame",
      "excalidraw.add_row",
      "excalidraw.add_column",
      "excalidraw.align_elements",
      "excalidraw.distribute_elements",
      "excalidraw.move_element",
      "excalidraw.group_elements",
      "excalidraw.set_elements_in_frame",
      "excalidraw.add_arrows",
      "excalidraw.add_elements",
      "excalidraw.remove_elements"
    ],
    "fileIcons": {
      "*.excalidraw": "draw"
    },
    "newFileMenu": [
      {
        "extension": ".excalidraw",
        "displayName": "Excalidraw Diagram",
        "icon": "draw",
        "defaultContent": "{\"type\":\"excalidraw\",\"version\":2,\"source\":\"https://excalidraw.com\",\"elements\":[],\"appState\":{\"gridSize\":null,\"viewBackgroundColor\":\"#ffffff\"},\"files\":{}}"
      }
    ],
    "nodes": ["ExcalidrawNode"],
    "transformers": ["EXCALIDRAW_TRANSFORMER"]
  }
}
