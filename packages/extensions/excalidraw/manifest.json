{
  "id": "com.nimbalyst.excalidraw",
  "name": "Excalidraw",
  "version": "1.0.0",
  "description": "Excalidraw diagram editor with AI-assisted editing",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "requiredReleaseChannel": "alpha",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.excalidraw"],
        "displayName": "Excalidraw Editor",
        "component": "ExcalidrawEditor",
        "supportsSourceMode": true
      }
    ],
    "aiTools": [
      "excalidraw.view_diagram",
      "excalidraw.get_elements",
      "excalidraw.add_rectangle",
      "excalidraw.add_arrow",
      "excalidraw.update_element",
      "excalidraw.remove_element",
      "excalidraw.create_group",
      "excalidraw.add_to_group",
      "excalidraw.remove_from_group",
      "excalidraw.relayout"
    ],
    "fileIcons": {
      "*.excalidraw": "pen-tool"
    },
    "newFileMenu": [
      {
        "extension": ".excalidraw",
        "displayName": "Excalidraw Diagram",
        "icon": "pen-tool",
        "defaultContent": "{\"type\":\"excalidraw\",\"version\":2,\"source\":\"https://excalidraw.com\",\"elements\":[],\"appState\":{\"gridSize\":null,\"viewBackgroundColor\":\"#ffffff\"},\"files\":{}}"
      }
    ],
    "nodes": ["ExcalidrawNode"],
    "transformers": ["EXCALIDRAW_TRANSFORMER"],
    "claudePlugin": {
      "path": "claude-plugin",
      "displayName": "Excalidraw Diagram Commands",
      "description": "Provides AI tools for creating and editing Excalidraw diagrams",
      "enabledByDefault": true,
      "commands": [
        {
          "name": "diagram",
          "description": "Create or modify Excalidraw diagrams"
        }
      ]
    }
  }
}
