datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A Stytch user. userId appears in JWT 'sub' claim. All personal DOs are keyed by (orgId, userId).
model User {
  /// / Stytch member_id
  id          String      @id
  /// / personalOrgId from Stytch
  orgId       String
}

/// A Stytch B2B organization. Can be personal (1 member) or team (N members).
model Organization {
  /// / Stytch organization_id
  id          String      @id
  /// / true if nimbalyst_org_type = 'personal'
  isPersonal  Boolean
}

/// PersonalIndexRoom -- one per user Room ID: org:{orgId}:user:{userId}:index Stores session index, project index, file index, device presence. Mobile connects here first for fast startup.
model PersonalIndexRoom {
  /// / = "user:{userId}:index"
  id          String      @id
  userId      String
  user User
}

/// Session entry in the PersonalIndexRoom
model PersonalIndexSession {
  sessionId   String      @id
  indexRoomId String
  projectIdIv String
  titleIv     String?
  /// / e.g. "claude-code", "claude-chat"
  provider    String?
  model       String?
  /// / "agent" | "planning"
  mode        String?
  createdAt   Int
  updatedAt   Int
  isExecuting Boolean     @default(false)
  /// / "session" | "workstream" | "blitz"
  sessionType String?
  worktreeId  String?
  isArchived  Boolean     @default(false)
  isPinned    Boolean     @default(false)
  lastReadAt  Int?
  personalIndexRooms PersonalIndexRoom[]
  personalSessionRoom PersonalSessionRoom @relation(fields: [sessionId], references: [sessionId])
}

/// Project entry in the PersonalIndexRoom
model PersonalIndexProject {
  /// / encrypted project path hash
  projectId   String      @id
  indexRoomId String
  projectIdIv String
  nameIv      String
  pathIv      String?
  syncEnabled Boolean     @default(true)
  configIv    String?
  personalIndexRooms PersonalIndexRoom[]
}

/// File index entry in PersonalIndexRoom (lightweight discovery for mobile)
model PersonalIndexFile {
  /// / syncId UUID from frontmatter
  docId       String      @id
  indexRoomId String
  projectIdIv String
  titleIv     String
  syncedAt    Int
  personalIndexRooms PersonalIndexRoom[]
}

/// PersonalSessionRoom -- one per session Room ID: org:{orgId}:user:{userId}:session:{sessionId} Stores E2E encrypted AI messages for a single session.
model PersonalSessionRoom {
  sessionId   String      @id
  userId      String
  users User[]
  personalIndexSession PersonalIndexSession
}

/// Encrypted message in a PersonalSessionRoom
model SessionMessage {
  /// / ULID for global ordering
  id          String      @id
  sessionId   String
  /// / monotonic within session
  sequence    Int
  createdAt   Int
  /// / "user" | "assistant" | "tool" | "system"
  source      String
  /// / "input" | "output"
  direction   String
  /// / base64 IV for decryption
  iv          String
  personalSessionRooms PersonalSessionRoom[]
}

/// Key-value metadata in a PersonalSessionRoom
model SessionMetadata {
  key         String      @id
  sessionId   String
  value       String
  updatedAt   Int
  personalSessionRooms PersonalSessionRoom[]
}

/// PersonalProjectSyncRoom -- one per (user + project) Room ID: org:{orgId}:user:{userId}:project:{projectId} Two-phase content model: encrypted markdown -> Yjs CRDT. Single WebSocket per project handles batch sync, incremental pushes, mobile prefetch.
model PersonalProjectSyncRoom {
  /// / = room ID
  id          String      @id
  userId      String
  users User[]
}

/// File in a PersonalProjectSyncRoom (two-phase: markdown -> Yjs)
model ProjectSyncFile {
  /// / UUID from YAML frontmatter
  syncId      String      @id
  roomId      String
  pathIv      String?
  titleIv     String?
  contentIv   String?
  /// / SHA-256 of plaintext for diff detection
  contentHash String?
  /// / encrypted Y.Doc snapshot (phase 2)
  yjsState    Bytes?
  yjsIv       String?
  yjsSeq      Int         @default(0)
  /// / false=markdown, true=Yjs active
  hasYjs      Boolean     @default(false)
  syncedAt    Int?
  createdAt   Int
  updatedAt   Int
  personalProjectSyncRooms PersonalProjectSyncRoom[]
}

/// Incremental Yjs update for a file in Yjs phase
model ProjectSyncYjsUpdate {
  id          Int         @id @default(autoincrement()
  syncId      String
  sequence    Int
  iv          String
  /// / which device sent this
  senderId    String?
  createdAt   Int
  projectSyncFiles ProjectSyncFile[]
}

/// TeamRoom -- one per organization Room ID: org:{orgId}:team Consolidated team state: members, ECDH keys, document index.
model TeamRoom {
  /// / = room ID
  id          String      @id
  orgId       String
  organization Organization
}

/// Team metadata (name, git remote, creator)
model TeamRoomMetadata {
  orgId       String      @id
  name        String
  /// / userId of creator
  createdBy   String
  createdAt   Int
  updatedAt   Int
  teamRoom TeamRoom
}

/// Member role in a team
model TeamMemberRole {
  userId      String      @id
  teamId      String
  /// / "admin" | "member"
  role        String      @default("member")
  email       String?
  updatedAt   Int
  users User[]
  teamRooms TeamRoom[]
}

/// ECDH P-256 public key for key exchange
model TeamIdentityKey {
  userId      String      @id
  teamId      String
  createdAt   Int
  updatedAt   Int
  teamRooms TeamRoom[]
}

/// Wrapped document encryption key for a target user (ECDH key exchange)
model TeamKeyEnvelope {
  teamId      String
  /// / AES key wrapped with derived ECDH shared secret
  wrappedKey  String
  iv          String
  createdAt   Int
  teamRooms TeamRoom[]
}

/// Document registered for team sharing
model TeamDocumentIndex {
  documentId  String      @id
  teamId      String
  titleIv     String
  /// / userId
  createdBy   String
  createdAt   Int
  updatedAt   Int
  teamRooms TeamRoom[]
  teamDocumentRoom TeamDocumentRoom @relation(fields: [documentId], references: [documentId])
}

/// TeamDocumentRoom -- one per shared document Room ID: org:{orgId}:doc:{documentId} Realtime collaborative Yjs editing with E2E encryption. Server is a dumb encrypted relay -- never reads Yjs state.
model TeamDocumentRoom {
  documentId  String      @id
  orgId       String
  organizations Organization[]
  teamDocumentIndex TeamDocumentIndex
}

/// Encrypted Yjs update in a TeamDocumentRoom
model DocEncryptedUpdate {
  id          Int         @id @default(autoincrement()
  documentId  String
  /// / encrypted Yjs update blob
  updateData  String
  iv          String
  senderId    String
  sequence    Int
  createdAt   Int
  teamDocumentRooms TeamDocumentRoom[]
}

/// Compacted Y.Doc state snapshot
model DocSnapshot {
  id          Int         @id @default(autoincrement()
  documentId  String
  iv          String
  createdAt   Int
  teamDocumentRooms TeamDocumentRoom[]
}

/// Per-user key envelope for document decryption (ECDH)
model DocKeyEnvelope {
  documentId  String
  wrappedKey  String
  iv          String
  createdAt   Int
  teamDocumentRooms TeamDocumentRoom[]
}

/// Binary asset attached to a document (stored in R2)
model DocAsset {
  assetId     String      @id
  documentId  String
  /// / R2 object key
  r2Key       String
  mimeType    String?
  metadataIv  String?
  createdBy   String
  createdAt   Int
  updatedAt   Int
  status      String      @default("ready")
  teamDocumentRooms TeamDocumentRoom[]
}

/// TeamTrackerRoom -- one per (org + project) Room ID: org:{orgId}:tracker:{projectId} Changelog-based encrypted tracker items with sequence-cursor sync.
model TeamTrackerRoom {
  /// / = room ID
  id          String      @id
  orgId       String
  organizations Organization[]
}

/// Encrypted tracker item (bug, task, decision, etc.)
model TrackerItem {
  itemId      String      @id
  trackerId   String
  /// / monotonic, incremented on each update
  version     Int
  iv          String
  createdAt   Int
  updatedAt   Int
  teamTrackerRooms TeamTrackerRoom[]
}

/// Changelog entry for tracker sync (cursor-based)
model TrackerChangelog {
  sequence    Int         @id @default(autoincrement()
  trackerId   String
  itemId      String
  /// / "upsert" | "delete"
  action      String
  iv          String?
  version     Int?
  createdAt   Int
  teamTrackerRooms TeamTrackerRoom[]
}
