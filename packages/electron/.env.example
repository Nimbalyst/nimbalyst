# Code Signing and Notarization Environment Variables
# Copy this file to .env and fill in your values

# Your Apple ID (email address)
APPLE_ID=your-apple-id@example.com

# App-specific password from https://appleid.apple.com
# Generate under Security > App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Team ID (already configured in notarize.js as 3GYP4YJ3DH)
# APPLE_TEAM_ID=3GYP4YJ3DH

# Optional: Skip notarization for local builds
# SKIP_NOTARIZE=true

# Optional: Require notarization to succeed (fail build if notarization fails)
# REQUIRE_NOTARIZE=true