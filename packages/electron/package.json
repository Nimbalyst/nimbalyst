{
  "name": "@stravu-editor/electron",
  "version": "0.33.1",
  "private": true,
  "description": "Electron app for Stravu Editor",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "dist": "electron-builder",
    "clean": "rm -rf node_modules/.vite out dist",
    " clean:dev": "rm -rf node_modules/.vite && npm run dev"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stravu-editor": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.stravu.editor",
    "productName": "Stravu Editor",
    "electronVersion": "37.2.6",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "../../assets/crystal-editor-iconset/icon.iconset",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
