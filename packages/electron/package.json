{
  "name": "@nimbalyst/electron",
  "version": "0.52.27",
  "private": true,
  "description": "Electron app for Nimbalyst",
  "main": "out/main/index.js",
  "bin": {
    "nimbalyst": "./bin/nimbalyst"
  },
  "scripts": {
    "start": "electron-vite preview",
    "dev": "./scripts/dev.sh",
    "dev:loop": "./scripts/dev-loop.sh",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=8192' electron-vite build && npm run build:worker",
    "build:worker": "node build/build-worker.js",
    "build:extensions": "node build/build-extensions.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "postinstall": "electron-builder install-app-deps || true",
    "build:unpack": "npm run build && npm run build:extensions && electron-builder --dir",
    "build:dist": "npm run build && npm run build:extensions && electron-builder",
    "build:mac": "npm run build && npm run build:extensions && node -r dotenv/config build/configure-build.js && node build/build-with-env.js --mac",
    "build:mac:signed": "npm run build && npm run build:extensions && node -r dotenv/config build/configure-build.js && node build/build-with-env.js --mac",
    "build:mac:notarized": "npm run build && npm run build:extensions && node -r dotenv/config build/configure-build.js && REQUIRE_NOTARIZE=true node build/build-with-env.js --mac",
    "build:mac:local": "SKIP_NOTARIZE=true npm run build && npm run build:extensions && SKIP_NOTARIZE=true node -r dotenv/config build/configure-build.js && SKIP_NOTARIZE=true node build/build-with-env.js --mac --publish never",
    "build:mac:release": "npm run build && npm run build:extensions && node -r dotenv/config build/configure-build.js && REQUIRE_NOTARIZE=true node build/build-with-env.js --mac --publish always",
    "build:win": "npm run build && npm run build:extensions && electron-builder --win --x64",
    "build:win:arm64": "npm run build && npm run build:extensions && electron-builder --win --arm64",
    "build:win:universal": "npm run build && npm run build:extensions && electron-builder --win --x64 --arm64",
    "build:linux": "npm run build && npm run build:extensions && electron-builder --linux",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ai": "vitest run ../runtime/src/ai/providers/__tests__/",
    "test:ai:watch": "vitest watch ../runtime/src/ai/providers/__tests__/",
    "test:e2e": "playwright test",
    "test:e2e:basic": "playwright test claude-code-basic.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.7",
    "@anthropic-ai/sdk": "^0.71.2",
    "@electric-sql/pglite": "^0.3.11",
    "@electron-toolkit/utils": "^4.0.0",
    "@excalidraw/excalidraw": "0.17.6",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@monaco-editor/react": "^4.7.0",
    "@nimbalyst/runtime": "*",
    "@stytch/vanilla-js": "^5.42.0",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^5.0.2",
    "@types/node-fetch": "^2.6.13",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "abort-controller": "^3.0.0",
    "agentkeepalive": "^4.6.0",
    "chardet": "^2.1.1",
    "chokidar": "^4.0.3",
    "diff": "^5.2.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "express-rate-limit": "^7.5.1",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "ghostty-web": "^0.4.0",
    "glob": "^11.0.3",
    "heic-decode": "^2.1.0",
    "html2canvas": "^1.4.1",
    "jimp": "^1.6.0",
    "jotai": "^2.16.1",
    "js-yaml": "^4.1.0",
    "json-schema-to-ts": "^3.1.1",
    "marked": "^16.4.0",
    "mcp-remote": "^0.1.37",
    "mermaid": "^11.12.0",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "openai": "^6.9.1",
    "pathe": "^2.0.3",
    "pdfjs-dist": "^4.10.38",
    "pkce-challenge": "^5.0.0",
    "posthog-js": "^1.280.1",
    "posthog-node": "^5.10.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.5.0",
    "rexical": "*",
    "simple-git": "^3.30.0",
    "ulid": "^3.0.1",
    "uuid": "^11.1.0",
    "virtua": "^0.48.2",
    "web-streams-polyfill": "^4.2.0",
    "ws": "^8.19.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.2",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.55.1",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.19.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "bufferutil": "^4.1.0",
    "dotenv": "^16.6.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "playwright": "^1.55.1",
    "playwright-electron": "^0.5.0",
    "postcss": "^8.4.0",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.45.0",
    "utf-8-validate": "^5.0.10",
    "vite": "^7.1.12",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.nimbalyst.electron",
    "productName": "Nimbalyst",
    "electronVersion": "37.2.6",
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nimbalyst",
        "repo": "nimbalyst-code",
        "releaseType": "release"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/@anthropic-ai/**/*",
      "node_modules/openai/**/*",
      "node_modules/heic-decode/**/*"
    ],
    "files": [
      "out/**/*",
      "icon.png",
      "nimbalyst-logo.png",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../../node_modules/node-pty",
        "to": "node-pty"
      },
      {
        "from": "../../node_modules/heic-decode",
        "to": "node_modules/heic-decode"
      },
      {
        "from": "../../node_modules/libheif-js",
        "to": "node_modules/libheif-js"
      },
      {
        "from": "out/worker.bundle.js",
        "to": "worker.bundle.js"
      },
      {
        "from": "../../node_modules/@electric-sql/pglite/dist/pglite.data",
        "to": "pglite.data"
      },
      {
        "from": "../../node_modules/@electric-sql/pglite/dist/pglite.wasm",
        "to": "pglite.wasm"
      },
      {
        "from": "resources/builtin-agents",
        "to": "builtin-agents"
      },
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "../extensions",
        "to": "extensions",
        "filter": [
          "**/manifest.json",
          "**/package.json",
          "**/dist/**",
          "**/claude-plugin/**"
        ]
      },
      {
        "from": "../extension-sdk-docs",
        "to": "extension-sdk-docs",
        "filter": [
          "**/*.md",
          "**/manifest.json",
          "**/package.json",
          "**/tsconfig.json",
          "**/vite.config.ts",
          "**/src/**"
        ]
      },
      {
        "from": "../../node_modules/@nimbalyst/runtime/dist/themes",
        "to": "node_modules/@nimbalyst/runtime/dist/themes"
      }
    ],
    "afterSign": "build/afterSign.js",
    "afterPack": "build/afterPack.js",
    "afterAllArtifactBuild": "build/afterAllArtifactBuild.js",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-macOS-${arch}.${ext}",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "signIgnore": [
        "node_modules/@anthropic-ai/claude-agent-sdk/vendor/.*\\.jar$"
      ],
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "Nimbalyst needs access to local network devices for features like MCP servers and local AI model connections.",
        "NSMicrophoneUsageDescription": "Nimbalyst uses the microphone for Voice Mode, allowing you to interact with the AI assistant using your voice."
      }
    },
    "dmg": {
      "format": "UDZO",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        }
      ],
      "artifactName": "${productName}-Windows.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "packElevateHelper": false
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "${productName}-Linux.${ext}"
    },
    "buildVersion": "0.36.5"
  }
}
