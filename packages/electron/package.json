{
  "name": "@stravu-editor/electron",
  "version": "0.33.1",
  "private": true,
  "description": "Electron app for Stravu Editor",
  "main": "out/main/index.js",
  "bin": {
    "stravueditor": "./bin/stravueditor"
  },
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps || true",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:dist": "npm run build && electron-builder",
    "build:mac": "npm run build && node -r dotenv/config build/configure-build.js && node build/build-with-env.js --mac",
    "build:mac:signed": "npm run build && node -r dotenv/config build/configure-build.js && node build/build-with-env.js --mac",
    "build:mac:notarized": "npm run build && node -r dotenv/config build/configure-build.js && REQUIRE_NOTARIZE=true node build/build-with-env.js --mac",
    "build:mac:local": "SKIP_NOTARIZE=true npm run build && SKIP_NOTARIZE=true node -r dotenv/config build/configure-build.js && SKIP_NOTARIZE=true node build/build-with-env.js --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ai": "vitest run src/main/services/ai/__tests__/",
    "test:ai:watch": "vitest watch src/main/services/ai/__tests__/"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.77",
    "@anthropic-ai/sdk": "^0.58.0",
    "@modelcontextprotocol/sdk": "^1.17.2",
    "dexie": "^4.0.11",
    "diff": "^5.2.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "openai": "^5.19.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stravu-editor": "*",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.2",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.19.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^16.6.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "happy-dom": "^18.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^5.2.11",
    "vite-plugin-static-copy": "^3.1.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.stravu.editor",
    "productName": "Preditor",
    "electronVersion": "37.2.6",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/@anthropic-ai/claude-code/**/*"
    ],
    "files": [
      "out/**/*",
      "icon.png",
      "node_modules/**/*",
      "!node_modules/@anthropic-ai/claude-code/vendor/**/*.jar"
    ],
    "afterSign": "build/afterSign.js",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "signIgnore": [
        "node_modules/@anthropic-ai/claude-code/vendor/.*\\.jar$"
      ],
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "dmg": {
      "format": "UDZO",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "packElevateHelper": false
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
