{
  "name": "@nimbalyst/capacitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "ios:dev": "npm run build && npx cap sync ios && npx cap open ios",
    "ios:build": "npm run build && npx cap sync ios",
    "devdeploy:ios": "npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^7.0.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/core": "^7.4.4",
    "@capacitor/preferences": "^7.0.2",
    "@nimbalyst/runtime": "file:../runtime",
    "capacitor-secure-storage-plugin": "^0.12.0",
    "node-forge": "^1.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@types/node-forge": "^1.3.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^7.1.12"
  }
}
