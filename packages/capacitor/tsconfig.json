{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "paths": {
      "@nimbalyst/runtime": ["../runtime/src"],
      "@nimbalyst/runtime/*": ["../runtime/src/*"],
      "rexical": ["../rexical/src"]
    }
  },
  "include": ["src"]
}
