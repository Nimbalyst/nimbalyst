{
  "name": "stravu-editor",
  "version": "0.34.0",
  "description": "A rich text editor built with Meta's Lexical framework, featuring markdown support, tables, and comprehensive editing capabilities",
  "keywords": [
    "react",
    "editor",
    "lexical",
    "markdown",
    "rich-text",
    "wysiwyg"
  ],
  "author": "Stravu Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stravu/stravu-editor.git"
  },
  "bugs": {
    "url": "https://github.com/stravu/stravu-editor/issues"
  },
  "homepage": "https://github.com/stravu/stravu-editor#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "preview": "vite preview",
    "clean": "rm -rf node_modules/.vite dist",
    "clean:build": "rm -rf node_modules/.vite dist && pnpm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@lexical/dragon": "^0.34.0",
    "@lexical/history": "^0.34.0",
    "lodash-es": "^4.17.21",
    "prettier": "^2.8.8",
    "react-error-boundary": "^3.1.4",
    "y-websocket": "^1.5.4",
    "yjs": ">=13.5.42"
  },
  "peerDependencies": {
    "@lexical/clipboard": "^0.34.0",
    "@lexical/code": "^0.34.0",
    "@lexical/code-shiki": "^0.34.0",
    "@lexical/file": "^0.34.0",
    "@lexical/hashtag": "^0.34.0",
    "@lexical/link": "^0.34.0",
    "@lexical/list": "^0.34.0",
    "@lexical/mark": "^0.34.0",
    "@lexical/markdown": "^0.34.0",
    "@lexical/overflow": "^0.34.0",
    "@lexical/plain-text": "^0.34.0",
    "@lexical/react": "^0.34.0",
    "@lexical/rich-text": "^0.34.0",
    "@lexical/selection": "^0.34.0",
    "@lexical/table": "^0.34.0",
    "@lexical/text": "^0.34.0",
    "@lexical/utils": "^0.34.0",
    "@lexical/yjs": "^0.34.0",
    "lexical": "^0.34.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.182",
    "@types/lodash-es": "^4.14.182",
    "@types/node": "^20.0.0",
    "@types/prettier": "^3.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.0.0",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-static-copy": "^2.3.0"
  },
  "sideEffects": false
}
